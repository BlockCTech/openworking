{
  "manifest_version": 3,
  "name": "TechTusCoWork Browser Bridge",
  "version": "1.0.0",
  "description": "Lets the TechTusCoWork desktop app drive your active Chrome tab (navigate, read, click, type, screenshot) through a local native-messaging host. Actions that change a page are confirmed in the app before they run.",
  "key": "",
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html", "default_title": "TechTusCoWork Browser Bridge" },
  "permissions": ["nativeMessaging", "activeTab", "scripting", "tabs", "alarms"],
  "minimum_chrome_version": "116"
}
